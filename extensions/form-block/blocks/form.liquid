{% comment %}
  PromptForm — Theme App Extension Block
  Add this block inside any section: Themes → Customize → Add block → Apps → PromptForm
{% endcomment %}

{% liquid
  assign form_id  = block.settings.form_id
  assign max_w    = block.settings.max_width | default: 600
%}

<div {{ block.shopify_attributes }}>
  {% if form_id != blank %}
    <div
      data-prompt-form
      data-form-ulid="{{ form_id }}"
      data-api-url="https://promptform.mesh99.com/api/public"
      style="max-width: {{ max_w }}px; margin: 0 auto;"
    ></div>
  {% else %}
    <div style="max-width: {{ max_w }}px; margin: 0 auto; padding: 32px 24px; background: #f9fafb; border: 2px dashed #d1d5db; border-radius: 10px; text-align: center; font-family: sans-serif;">
      <p style="margin: 0 0 6px; font-size: 15px; font-weight: 600; color: #374151;">PromptForm</p>
      <p style="margin: 0; font-size: 13px; color: #6b7280;">
        Open the block settings panel and paste your <strong>Form ID</strong> to display your form here.
      </p>
    </div>
  {% endif %}

  <script>
    (function () {
      var WIDGET_SRC = {{ 'form-widget.js' | asset_url | json }};

      function run() {
        if (window.PromptFormWidget) {
          window.PromptFormWidget.init();
          return;
        }
        if (window.__pfLoading) return;
        window.__pfLoading = true;
        var s = document.createElement('script');
        s.src = WIDGET_SRC;
        s.async = true;
        s.onload = function () {
          window.__pfLoading = false;
          if (window.PromptFormWidget) window.PromptFormWidget.init();
        };
        document.head.appendChild(s);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run);
      } else {
        run();
      }

      document.addEventListener('shopify:section:load', run);
    })();
  </script>
</div>

{% schema %}
{
  "name": "PromptForm",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "form_id",
      "label": "Form ID",
      "info": "Copy the Form ID from the PromptForm app (Forms → your form → copy the ID shown at the top)."
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max width (px)",
      "min": 300,
      "max": 900,
      "step": 50,
      "default": 600
    }
  ]
}
{% endschema %}
